{
  "name": "mathboard",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "tsx --watch-path server.ts --watch-path src/server server.ts",
    "build": "prisma generate && next build",
    "start": "NODE_ENV=production npx tsx server.ts",
    "dev:next": "next dev",
    "lint": "eslint",
    "test": "vitest run",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.3.1",
    "jspdf": "^4.2.0",
    "next": "16.1.6",
    "next-auth": "^5.0.0-beta.30",
    "pdfjs-dist": "^5.5.207",
    "prisma": "^7.5.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "tldraw": "^4.4.1",
    "ws": "^8.19.0",
    "y-indexeddb": "^9.0.12",
    "yjs": "^13.6.30"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/ws": "^8.18.1",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "prettier": "^3.8.1",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.0"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
