# ===========================================
# Local Development
# ===========================================

# Database (local: use port from docker-compose dev DB or local Postgres)
DATABASE_URL="postgresql://mathboard:mathboard123@localhost:5432/mathboard?schema=public"

# Auth.js (NextAuth v5)
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="generate-a-random-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# File uploads
UPLOAD_DIR="./uploads"

# AI Provider ("claude" or "openai")
AI_PROVIDER=claude
AI_API_KEY=your-api-key-here

# ===========================================
# Docker Compose / Production
# ===========================================

# Postgres password (used by docker-compose for both db and app service)
POSTGRES_PASSWORD=mathboard_secret

# App port mapping (docker-compose)
PORT=3000
